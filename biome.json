{
  "$schema": "https://biomejs.dev/schemas/2.3.13/schema.json",
  "extends": ["ultracite/biome/core"],
  "root": true,
  "overrides": [
    {
      "includes": ["test/**"],
      "linter": {
        "rules": {
          "performance": {
            "useTopLevelRegex": "off"
          },
          "suspicious": {
            "noControlCharactersInRegex": "off"
          }
        }
      }
    }
  ]
}
