{
  "name": "@howells/claudeusage",
  "version": "1.0.1",
  "description": "CLI to check Claude usage across multiple accounts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/howells/claudeusage.git"
  },
  "type": "module",
  "bin": {
    "claudeusage": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "tsc && node scripts/insert-shebang.js",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "tsx --test test/**/*.test.ts",
    "prepublishOnly": "npm run build",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "playwright-core": "^1.49.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/node": "^22.10.0",
    "husky": "9.1.7",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "ultracite": "7.3.2",
    "lint-staged": "^16.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.15.1",
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,jsonc,css}": "biome format --write --no-errors-on-unmatched"
  }
}
