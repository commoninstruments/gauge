{
  "name": "@howells/gauge",
  "version": "2.0.0",
  "description": "At-a-glance usage dashboard for Claude, Codex, and Cursor accounts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/howells/gauge.git"
  },
  "type": "module",
  "bin": {
    "gauge": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "tsc && node scripts/insert-shebang.js",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "tsx --test test/**/*.test.ts",
    "prepublishOnly": "npm run build",
    "lint": "howells-lint",
    "format": "howells-format",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "playwright-core": "^1.49.0"
  },
  "devDependencies": {
    "@howells/lint": "*",
    "@howells/typescript-config": "^0.1.2",
    "@types/node": "^22.10.0",
    "husky": "9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.15.1",
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,jsonc,css}": "howells-format"
  }
}
